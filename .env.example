# ===========================================
# Game Account Exchange - Environment Variables
# ===========================================
# Usage:
# 1. Copy this file as .env
# 2. Fill in the actual values
# 3. DO NOT commit .env to version control

# ===========================================
# LangSmith Configuration (for tracing and debugging)
# ===========================================
LANGSMITH_PROJECT=your_project_name
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=false

# ===========================================
# LLM Configuration (required)
# ===========================================
# Your LLM API provider (e.g., OpenAI, Anthropic, OpenRouter, etc.)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODELS=["gpt-4o", "gpt-4o-mini"]
LLM_TIMEOUT=60

# ===========================================
# Database Configuration (required)
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_DATABASE=game_account_exchange

# ===========================================
# Snowflake ID Configuration
# ===========================================
SNOWFLAKE_MACHINE_ID=1
SNOWFLAKE_DATA_CENTER_ID=1

# ===========================================
# Environment Configuration
# ===========================================
DEBUG=true

HOST=localhost
# Backend LangGraph API server port
BACKEND_PORT=8080
# API Server port (FastAPI)
API_PORT=8081
# Frontend Configuration
FRONTEND_PORT=8082